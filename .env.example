# ipekciapp.com — örnek environment değişkenleri
# Bu dosya commit edilir. Gerçek değerler .env.local içine yazılır (asla commit edilmez).

# Site
NEXT_PUBLIC_SITE_URL=                # https://ipekciapp.com — canonical, OpenGraph ve metadata için

# Supabase — workspace auth (Magic Link + TOTP 2FA)
NEXT_PUBLIC_SUPABASE_URL=            # Supabase project URL (https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # Public anon key — RLS koruması altında client tarafında okunur
SUPABASE_SERVICE_ROLE_KEY=           # SADECE server-side. Asla client'a expose etme.

# Workspace allowlist — virgülle ayrılmış e-posta listesi. Bu listede olmayan kullanıcı
# auth olsa bile /workspace'e giremez. Default tek kullanıcı: snr061@gmail.com.
WORKSPACE_ALLOWED_EMAILS=            # snr061@gmail.com

# Brevo — gelecekte transactional email (workspace alerts, magic link fallback) için
BREVO_API_KEY=
